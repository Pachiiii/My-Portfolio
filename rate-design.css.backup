/* Enhanced Rate My Portfolio Design */
.feedback-section {
  padding: 35px;
  background: linear-gradient(145deg, var(--bg-tertiary), rgba(255, 215, 0, 0.05));
  border: 2px solid rgba(255, 215, 0, 0.3);
  border-radius: 25px;
  backdrop-filter: blur(25px);
  box-shadow: 
    0 25px 60px var(--shadow-md),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.feedback-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5px;
  background: linear-gradient(90deg, var(--accent-color), var(--text-secondary), var(--accent-color));
  border-radius: 25px 25px 0 0;
}

.feedback-section h4 {
  color: var(--accent-color);
  font-size: 1.3em;
  font-weight: 700;
  text-align: center;
  margin-bottom: 25px;
}

.stars {
  display: flex;
  gap: 8px;
  margin-bottom: 25px;
  justify-content: center;
  background: rgba(255, 215, 0, 0.15);
  padding: 20px;
  border-radius: 20px;
  border: 2px solid rgba(255, 215, 0, 0.4);
  box-shadow: inset 0 0 20px rgba(255, 215, 0, 0.1);
}

.stars i {
  font-size: 2.2em;
  color: var(--text-tertiary);
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  padding: 12px;
  border-radius: 50%;
  position: relative;
}

.stars i:hover, 
.stars i.active {
  color: #ffd700 !important;
  transform: scale(1.3) rotate(5deg);
  text-shadow: 0 0 25px #ffd700;
  background: linear-gradient(145deg, rgba(255, 215, 0, 0.3), rgba(255, 215, 0, 0.1));
  box-shadow: 
    0 10px 30px rgba(255, 215, 0, 0.4),
    inset 0 0 10px rgba(255, 255, 255, 0.2);
}

.feedback-section textarea {
  width: 100%;
  height: 140px;
  padding: 20px;
  background: var(--bg-secondary);
  border: 2px solid rgba(255, 215, 0, 0.2);
  border-radius: 20px;
  color: var(--text-primary);
  font-family: 'Poppins', sans-serif;
  resize: none;
  transition: all 0.3s ease;
  font-size: 1em;
}

.feedback-section textarea:focus {
  border-color: #ffd700;
  box-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
  transform: translateY(-2px);
}

.feedback-section textarea::placeholder {
  color: var(--text-tertiary);
  font-style: italic;
}

.feedback-btn {
  width: 100%;
  margin-top: 20px;
  background: linear-gradient(90deg, #ffd700, #ffed4e);
  color: #000;
  font-weight: 700;
  box-shadow: 0 10px 30px rgba(255, 215, 0, 0.4);
}

.feedback-btn:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: 0 15px 40px rgba(255, 215, 0, 0.6);
}

/* Light mode adjustments */
body.light-mode .feedback-section {
  background: linear-gradient(145deg, rgba(0, 0, 0, 0.05), rgba(255, 215, 0, 0.03));
  border-color: rgba(255, 215, 0, 0.4);
}

body.light-mode .stars {
  background: rgba(255, 215, 0, 0.2);
  border-color: rgba(255, 215, 0.5);
}
